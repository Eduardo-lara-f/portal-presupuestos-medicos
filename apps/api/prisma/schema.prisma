generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  SUPER_ADMIN
  DIVISION_ADMIN
  BUDGET_HEAD
  EXECUTIVE
  MAINTAINER
  VIEWER
}

enum CareType {
  AMBULATORY
  SURGICAL
  BOTH
}

enum ProfessionalType {
  STAFF
  EXTERNAL
}

enum CoverageType {
  ISAPRE_PLAN
  FONASA
  PARTICULAR
  OTHER
}

enum QuoteStatus {
  DRAFT
  FINALIZED
  SENT
}


enum QuoteItemSourceType {
  PROCEDURE
  SUPPLY
  MEDICATION
  BED_DAY
  MEDICAL_FEE
  PACKAGE
  BASKET
  MANUAL
}

enum CatalogItemType {
  PROCEDURE
  SUPPLY
  MEDICATION
  BED_DAY
  MEDICAL_FEE
}

enum MedicalPackageType {
  CONVENTIONAL
  PAD
}

enum PadCoverageMode {
  NONE
  STANDARD
  PARTO_CESAREA
}

model Corporation {
  id        Int        @id @default(autoincrement())
  name      String
  code      String     @unique
  status    Boolean    @default(true)
  divisions Division[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  deletedAt DateTime?
}

model Division {
  id                    Int                    @id @default(autoincrement())
  corporationId         Int?
  corporation           Corporation?           @relation(fields: [corporationId], references: [id])
  name                  String
  code                  String                 @unique
  status                Boolean                @default(true)
  brandPrimaryColor     String                 @default("#0F4C81")
  brandSecondaryColor   String                 @default("#2C8ED6")
  brandAccentColor      String                 @default("#22C55E")
  brandLogoKey          String                 @default("generic-health")
  users                 User[]
  patients              Patient[]
  procedures            Procedure[]
  prices                ProcedurePrice[]
  professionals         Professional[]
  medicalFees           MedicalFee[]
  packages              MedicalPackage[]
  baskets               Basket[]
  quotes                Quote[]
  divisionIsapres       DivisionIsapre[]
  procedurePackageLinks ProcedurePackageLink[]
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  deletedAt             DateTime?
}

model User {
  id           Int       @id @default(autoincrement())
  divisionId   Int?
  division     Division? @relation(fields: [divisionId], references: [id])
  name         String
  email        String    @unique
  passwordHash String
  googleId     String?
  role         UserRole
  careAccess   CareType  @default(BOTH)
  status       Boolean   @default(true)
  quotes       Quote[]   @relation("QuoteCreatedBy")
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?
}

model Patient {
  id         Int       @id @default(autoincrement())
  divisionId Int
  division   Division  @relation(fields: [divisionId], references: [id])
  rut        String
  firstName  String
  lastName   String
  middleName String?
  birthDate  DateTime?
  sex        String?
  email      String?
  phone      String?
  address    String?
  quotes     Quote[]
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  deletedAt  DateTime?

  @@unique([divisionId, rut])
}

model Isapre {
  id              Int              @id @default(autoincrement())
  name            String
  code            String           @unique
  active          Boolean          @default(true)
  plans           IsaprePlan[]
  divisionLinks   DivisionIsapre[]
  procedurePrices ProcedurePrice[]
  medicalFees     MedicalFee[]
  quotes          Quote[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  deletedAt       DateTime?
}

model IsaprePlan {
  id              Int              @id @default(autoincrement())
  isapreId        Int
  isapre          Isapre           @relation(fields: [isapreId], references: [id])
  name            String
  code            String?
  active          Boolean          @default(true)
  procedurePrices ProcedurePrice[]
  medicalFees     MedicalFee[]
  quotes          Quote[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  deletedAt       DateTime?

  @@unique([isapreId, name])
}

model DivisionIsapre {
  id         Int       @id @default(autoincrement())
  divisionId Int
  division   Division  @relation(fields: [divisionId], references: [id])
  isapreId   Int
  isapre     Isapre    @relation(fields: [isapreId], references: [id])
  active     Boolean   @default(true)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  deletedAt  DateTime?

  @@unique([divisionId, isapreId])
}

model Procedure {
  id           Int                    @id @default(autoincrement())
  divisionId   Int
  division     Division               @relation(fields: [divisionId], references: [id])
  code         String
  name         String
  description  String?
  category     String?
  itemType     CatalogItemType         @default(PROCEDURE)
  careType     CareType               @default(BOTH)
  active       Boolean                @default(true)
  prices       ProcedurePrice[]
  medicalFees  MedicalFee[]
  packageLinks ProcedurePackageLink[]
  packageItems MedicalPackageItem[]
  basketItems  BasketItem[]
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt
  deletedAt    DateTime?

  @@unique([divisionId, code])
}

model ProcedurePrice {
  id            Int          @id @default(autoincrement())
  divisionId    Int
  division      Division     @relation(fields: [divisionId], references: [id])
  procedureId   Int
  procedure     Procedure    @relation(fields: [procedureId], references: [id])
  coverageType  CoverageType
  isapreId      Int?
  isapre        Isapre?      @relation(fields: [isapreId], references: [id])
  isaprePlanId  Int?
  isaprePlan    IsaprePlan?  @relation(fields: [isaprePlanId], references: [id])
  fonasaCode    String?
  payerLabel    String?
  price         Decimal      @db.Decimal(12, 2)
  currency      String       @default("CLP")
  effectiveFrom DateTime?
  effectiveTo   DateTime?
  active        Boolean      @default(true)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  deletedAt     DateTime?
}

model Professional {
  id           Int                 @id @default(autoincrement())
  divisionId   Int
  division     Division            @relation(fields: [divisionId], references: [id])
  type         ProfessionalType
  rut          String?
  firstName    String
  lastName     String
  specialty    String?
  email        String?
  phone        String?
  active       Boolean             @default(true)
  medicalFees  MedicalFee[]
  quoteMembers QuoteProfessional[]
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  deletedAt    DateTime?
}

model MedicalFee {
  id             Int          @id @default(autoincrement())
  divisionId     Int
  division       Division     @relation(fields: [divisionId], references: [id])
  professionalId Int
  professional   Professional @relation(fields: [professionalId], references: [id])
  procedureId    Int
  procedure      Procedure    @relation(fields: [procedureId], references: [id])
  coverageType   CoverageType
  isapreId       Int?
  isapre         Isapre?      @relation(fields: [isapreId], references: [id])
  isaprePlanId   Int?
  isaprePlan     IsaprePlan?  @relation(fields: [isaprePlanId], references: [id])
  feeType        String?
  amount         Decimal      @db.Decimal(12, 2)
  active         Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  deletedAt      DateTime?
}

model MedicalPackage {
  id              Int                    @id @default(autoincrement())
  divisionId      Int
  division        Division               @relation(fields: [divisionId], references: [id])
  code            String
  name            String
  description     String?
  packageType     MedicalPackageType     @default(CONVENTIONAL)
  padCoverageMode PadCoverageMode        @default(NONE)
  active          Boolean                @default(true)
  items           MedicalPackageItem[]
  procedureLinks  ProcedurePackageLink[]
  campaigns       Campaign[]
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt
  deletedAt       DateTime?

  @@unique([divisionId, code])
}

model MedicalPackageItem {
  id          Int            @id @default(autoincrement())
  packageId   Int
  package     MedicalPackage @relation(fields: [packageId], references: [id])
  procedureId Int
  procedure   Procedure      @relation(fields: [procedureId], references: [id])
  quantity    Int            @default(1)
  priceMode   String         @default("AGREEMENT_PRICE")
  fixedPrice  Decimal?       @db.Decimal(12, 2)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  deletedAt   DateTime?
}

model ProcedurePackageLink {
  id          Int            @id @default(autoincrement())
  procedureId Int
  procedure   Procedure      @relation(fields: [procedureId], references: [id])
  packageId   Int
  package     MedicalPackage @relation(fields: [packageId], references: [id])
  divisionId  Int
  division    Division       @relation(fields: [divisionId], references: [id])
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  deletedAt   DateTime?

  @@unique([procedureId, packageId])
}

model Basket {
  id          Int          @id @default(autoincrement())
  divisionId  Int
  division    Division     @relation(fields: [divisionId], references: [id])
  code        String
  name        String
  description String?
  active      Boolean      @default(true)
  items       BasketItem[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  deletedAt   DateTime?

  @@unique([divisionId, code])
}

model BasketItem {
  id             Int       @id @default(autoincrement())
  basketId       Int
  basket         Basket    @relation(fields: [basketId], references: [id])
  procedureId    Int
  procedure      Procedure @relation(fields: [procedureId], references: [id])
  quantity       Int       @default(1)
  relevanceScore Decimal?  @db.Decimal(5, 2)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?
}

model Quote {
  id              Int                 @id @default(autoincrement())
  divisionId      Int
  division        Division            @relation(fields: [divisionId], references: [id])
  patientId       Int
  patient         Patient             @relation(fields: [patientId], references: [id])
  coverageType    CoverageType
  isapreId        Int?
  isapre          Isapre?             @relation(fields: [isapreId], references: [id])
  isaprePlanId    Int?
  isaprePlan      IsaprePlan?         @relation(fields: [isaprePlanId], references: [id])
  fonasaCode      String?
  payerLabel      String?
  careType        CareType
  status          QuoteStatus         @default(DRAFT)
  validityDays    Int                 @default(15)
  subtotal        Decimal             @db.Decimal(12, 2)
  discountTotal   Decimal             @db.Decimal(12, 2)
  total           Decimal             @db.Decimal(12, 2)
  notes           String?
  pdfS3Key        String?
  pdfGeneratedAt  DateTime?
  createdByUserId Int
  createdBy       User                @relation("QuoteCreatedBy", fields: [createdByUserId], references: [id])
  professionals   QuoteProfessional[]
  items           QuoteItem[]
  emailLogs       QuoteEmailLog[]
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  deletedAt       DateTime?
}

model QuoteProfessional {
  id               Int              @id @default(autoincrement())
  quoteId          Int
  quote            Quote            @relation(fields: [quoteId], references: [id])
  professionalId   Int
  professional     Professional     @relation(fields: [professionalId], references: [id])
  roleInSurgery    String?
  professionalType ProfessionalType
  feeAmount        Decimal          @db.Decimal(12, 2)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  deletedAt        DateTime?
}

model QuoteItem {
  id          Int                 @id @default(autoincrement())
  quoteId     Int
  quote       Quote               @relation(fields: [quoteId], references: [id])
  sourceType  QuoteItemSourceType
  sourceId    Int
  description String
  quantity    Int
  unitPrice   Decimal
  totalPrice  Decimal
  type        String
  editable    Boolean             @default(true)
  parentId    Int?
  parent      QuoteItem?          @relation("QuoteItemHierarchy", fields: [parentId], references: [id])
  children    QuoteItem[]         @relation("QuoteItemHierarchy")
  deletedAt   DateTime?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
}

model QuoteEmailLog {
  id             Int       @id @default(autoincrement())
  quoteId        Int
  quote          Quote     @relation(fields: [quoteId], references: [id])
  recipientEmail String
  recipientType  String
  sentAt         DateTime?
  status         String
  errorMessage   String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?
}

model Campaign {
  id                 Int      @id @default(autoincrement())
  name               String
  packageId          Int
  discountPercentage Decimal
  active             Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  package MedicalPackage @relation(fields: [packageId], references: [id])
}
